{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$comment": "범용 how-to 프로파일. 시간 값은 MM:SS 문자열이며 클라이언트가 초 단위로 정규화한다.",
  "title": "clipnote generic analysis result",
  "type": "object",
  "required": ["title", "summary", "category", "materials", "steps", "visual_guides"],
  "properties": {
    "title": {"type": "string"},
    "summary": {"type": "string"},
    "category": {"type": "string"},
    "materials": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "amount"],
        "properties": {
          "name": {"type": "string"},
          "amount": {"type": "string"}
        }
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "summary", "detail", "t_start", "t_end"],
        "properties": {
          "id": {"type": "integer"},
          "summary": {"type": "string"},
          "detail": {"type": "string"},
          "t_start": {"type": "string", "pattern": "^[0-9]{1,3}:[0-9]{2}$"},
          "t_end": {"type": "string", "pattern": "^[0-9]{1,3}:[0-9]{2}$"}
        }
      }
    },
    "visual_guides": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "step_id", "source_phrase", "phrase", "type", "what_to_show", "best_visual_timestamp", "guide_text", "importance"],
        "properties": {
          "id": {"type": "string", "pattern": "^vg-[1-9][0-9]*$"},
          "step_id": {"type": "integer"},
          "source_phrase": {"type": "string"},
          "phrase": {"type": "string"},
          "type": {"enum": ["size", "thickness", "color", "state", "amount", "position", "angle", "action", "texture"]},
          "what_to_show": {"type": "string"},
          "best_visual_timestamp": {
            "oneOf": [
              {"type": "null"},
              {"type": "string", "pattern": "^[0-9]{1,3}:[0-9]{2}$"}
            ]
          },
          "guide_text": {"type": "string"},
          "importance": {"type": "number", "minimum": 0, "maximum": 1}
        }
      }
    }
  }
}
